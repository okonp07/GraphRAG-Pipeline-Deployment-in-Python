[app]
chunk_size = 400
chunk_overlap = 50
embedding_model = "sentence-transformers/all-MiniLM-L6-v2"
embedding_dim = 256
graph_weight = 0.5
vector_weight = 0.5
top_k = 5

[neo4j]
enabled = true
uri = "neo4j+s://YOUR-AURA-ENDPOINT.databases.neo4j.io"
username = "neo4j"
password = "replace-me"
database = "neo4j"

[storage]
backend = "s3"
bucket = "your-graphrag-bucket"
prefix = "graphrag/production"
region = "us-east-1"
endpoint_url = ""
aws_access_key_id = "replace-me"
aws_secret_access_key = "replace-me"
local_vector_store_path = "artifacts/vector_store"
local_document_store_path = "artifacts/documents.json"
